generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Subject {
  id       String          @id
  name     String
  icon     String
  articles Article[]
  plans    PlanItem[]
  material SubjectMaterial?
}

model SubjectMaterial {
  id        String   @id @default(cuid())
  subjectId String   @unique
  content   String?  @db.LongText
  updatedAt DateTime @updatedAt
  subject   Subject  @relation(fields: [subjectId], references: [id])
}

model SubjectCases {
  id        String   @id @default(cuid())
  subjectId String   @unique
  content   String   @db.LongText
  updatedAt DateTime @updatedAt
}

model Article {
  id          String   @id @default(cuid())
  subjectId   String
  title       String   @db.VarChar(500)
  summaryPath String   @db.VarChar(500)
  url         String   @db.VarChar(1000)
  source      String
  publishedAt DateTime
  createdAt   DateTime @default(now())
  subject     Subject  @relation(fields: [subjectId], references: [id])

  @@unique([url])
  @@index([subjectId, publishedAt(sort: Desc)])
}

model DailyPlan {
  id        String     @id @default(cuid())
  date      DateTime   @unique @db.Date
  items     PlanItem[]
  createdAt DateTime   @default(now())
}

model PlanItem {
  id          String    @id @default(cuid())
  planId      String
  subjectId   String
  title       String    @db.VarChar(500)
  contentPath String    @db.VarChar(500)
  articleId   String?
  done        Boolean   @default(false)
  plan        DailyPlan @relation(fields: [planId], references: [id])
  subject     Subject   @relation(fields: [subjectId], references: [id])

  @@index([planId])
}

model Exam {
  id        String         @id @default(cuid())
  weekStart DateTime       @unique @db.Date
  questions ExamQuestion[]
  createdAt DateTime       @default(now())
}

model ExamQuestion {
  id          String      @id @default(cuid())
  examId      String
  subject     String
  options     String      @db.Text
  answer      String      @db.Char(1)
  contentPath String      @db.VarChar(500)
  exam        Exam        @relation(fields: [examId], references: [id])
  userAns     UserAnswer?

  @@index([examId])
}

model UserAnswer {
  id         String       @id @default(cuid())
  questionId String       @unique
  answer     String       @db.Char(1)
  correct    Boolean
  question   ExamQuestion @relation(fields: [questionId], references: [id])
}

model Progress {
  id             String   @id @default(cuid())
  subjectId      String
  weekStart      DateTime @db.Date
  score          Int?
  totalQ         Int?
  evaluationPath String?  @db.VarChar(500)

  @@unique([subjectId, weekStart])
  @@index([weekStart])
}

model DailyEnglish {
  id         String   @id @default(cuid())
  date       DateTime @unique @db.Date
  topic      String   @db.VarChar(200)
  articleEn  String   @db.Text
  articleZh  String   @db.Text
  vocabulary String   @db.Text  // JSON: [{word, phonetic, meaning, example}]
  phrases    String   @db.Text  // JSON: [{phrase, meaning, example, exampleZh}]
  createdAt  DateTime @default(now())
}

model MedicalRecord {
  id         String   @id @default(cuid())
  type       String   @db.VarChar(50)   // checkup | lab | imaging | prescription | other
  title      String   @db.VarChar(300)
  recordDate DateTime @db.Date
  filePath   String?  @db.VarChar(500)
  fileExt    String?  @db.VarChar(10)
  mimeType   String?  @db.VarChar(100)
  notes      String?  @db.Text
  aiSummary  String?  @db.LongText
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([recordDate(sort: Desc)])
}

model ChatSession {
  id        String        @id @default(cuid())
  title     String?       @db.VarChar(300)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String      @db.VarChar(10)
  content   String      @db.LongText
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model HSMaterial {
  id           String   @id @default(cuid())
  subject      String   @unique
  basicPath    String?  @db.VarChar(500)
  advancedPath String?  @db.VarChar(500)
  updatedAt    DateTime @updatedAt
}

model HSWrongAnswer {
  id           String   @id @default(cuid())
  subject      String
  imagePath    String?  @db.VarChar(500)
  mimeType     String?  @db.VarChar(100)
  analysisJson String?  @db.LongText
  createdAt    DateTime @default(now())

  @@index([subject])
  @@index([createdAt(sort: Desc)])
}

model BookDownload {
  id        String   @id @default(cuid())
  subjectId String
  title     String   @db.VarChar(500)
  author    String?  @db.VarChar(300)
  filePath  String?  @db.VarChar(500)
  md5       String?  @db.Char(32)
  extension String?  @db.VarChar(10)
  status      String   @default("pending") // pending | downloading | done | failed
  noteContent String?  @db.LongText
  error       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([subjectId, title])
  @@index([subjectId])
  @@index([status])
}
